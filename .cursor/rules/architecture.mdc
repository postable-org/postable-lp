## 📝 Code Patterns

### TypeScript: Always Typed Props
```typescript
// ✅ GOOD
interface ButtonProps {
  variant?: 'primary' | 'secondary' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  onClick?: (e: React.MouseEvent<HTMLButtonElement>) => void;
  children: React.ReactNode;
}

export const Button = ({ variant = 'primary', ...props }: ButtonProps) => { }

// ❌ BAD
export const Button = (props: any) => { }
```

### Composition in Molecules
```typescript
// ✅ GOOD: Molecule composed of Atoms
export const SearchBar = ({ onSearch }: SearchBarProps) => (
  <div className="search-bar">
    <Input placeholder="Search..." />
    <Button>Search</Button>
  </div>
)

// ❌ BAD: Complex logic, importing Organisms
import { ProductList } from '../organisms/ProductList';
export const SearchBar = ({ onSearch }: SearchBarProps) => { }
```

### Data Passing in Organisms
```typescript
// ✅ GOOD: Organism receives data via props
export const ProductCard = ({ product, onAddCart }: ProductCardProps) => (
  <div>
    <h2>{product.name}</h2>
    <Button onClick={() => onAddCart(product.id)}>Add to Cart</Button>
  </div>
)

// ❌ BAD: Organism calls API directly
export const ProductCard = ({ productId }: ProductCardProps) => {
  const [product, setProduct] = useState(null);
  useEffect(() => { fetch(`/api/products/${productId}`); }, []);
}
```

### Centralized Logic in Pages
```typescript
// ✅ GOOD: Page manages data, passes to components
export const ProductPage = ({ productId }: { productId: string }) => {
  const [product, setProduct] = useState(null);
  
  useEffect(() => {
    fetch(`/api/products/${productId}`).then(setProduct);
  }, [productId]);
  
  return <ProductCard product={product} onAddCart={addToCart} />;
}
```

